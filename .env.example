# whisper_transcribe configuration
# Copy this file to .env and edit the values for your setup.
# ---------------------------------------------------------------

# Path to the folder containing audio/video files to transcribe.
# Subfolders are scanned recursively.
# Windows paths: backslashes are fine without quoting (no spaces).
# Paths WITH spaces: wrap in single quotes, e.g.:
#   folderPath='C:\My Recordings\With Spaces'
# UNC (network share) paths:
#   folderPath=\\server\share\folder
folderPath=./audios

# Device preference: gpu, cpu, or leave empty to auto-detect on first run.
# If empty, the script detects your hardware and asks when ambiguous.
# Your choice is then saved here automatically so you won't be asked again.
#   gpu  — force CUDA/GPU (falls back to CPU silently if CUDA unavailable)
#   cpu  — always use CPU
#   (empty) — auto-detect and save on first run
device=

# Comma-separated output types to generate: srt, txt, vtt
# Leave empty to generate all three.
# TranscribeType=srt,txt,vtt
TranscribeType=

# Optional: output folder for generated files.
# If set, output files are placed here instead of next to the source audio.
# Filenames are prefixed with the source file's creation datetime:
#   yyyymmddHHMMSS_originalname.ext
# Paths WITH spaces: wrap in single quotes (same rule as folderPath).
# outputPath=
outputPath=

# Max parallel transcription workers.
# Model weights are loaded once and shared (VRAM does not multiply).
#   GPU: 2-3 recommended
#   CPU: 4-8 recommended depending on core count
maxWorkers=1
